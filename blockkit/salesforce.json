      "blocks": [
        { "type": "header", "text": { "type": "plain_text", "text": "🎉 Opportunity Closed Won", "emoji": true } },
        { "type": "section", "fields": [
          { "type": "mrkdwn", "text": "*Opportunity:*\nAcme Corp — Platform Expansion" },
          { "type": "mrkdwn", "text": "*Amount:*\n$250,000" },
          { "type": "mrkdwn", "text": "*Stage:*\nClosed Won" },
          { "type": "mrkdwn", "text": "*Owner:*\nFrank Reynolds" }
        ] },
        { "type": "context", "elements": [
          { "type": "mrkdwn", "text": "Close date 2026-03-31 · Account: Acme Corp" }
        ] }
      ]
    },
    {
      "name": "opportunity_updated",
      "when": "An open opportunity changes stage or amount.",
      "blocks": [
        { "type": "header", "text": { "type": "plain_text", "text": "📈 Opportunity Updated", "emoji": true } },
        { "type": "section", "fields": [
          { "type": "mrkdwn", "text": "*Opportunity:*\nAcme Corp — Platform Expansion" },
          { "type": "mrkdwn", "text": "*Stage:*\nNegotiation/Review" },
          { "type": "mrkdwn", "text": "*Amount:*\n$250,000" },
          { "type": "mrkdwn", "text": "*Close Date:*\n2026-06-30" }
        ] },
        { "type": "context", "elements": [
          { "type": "mrkdwn", "text": "Updated by Frank Reynolds · 60% probability" }
        ] }
      ]
    }
  ]
}
